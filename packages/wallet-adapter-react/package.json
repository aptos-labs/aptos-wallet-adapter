{
  "name": "@aptos-labs/wallet-adapter-react",
  "version": "8.3.3",
  "description": "Aptos Wallet Adapter React Provider",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "exports": {
