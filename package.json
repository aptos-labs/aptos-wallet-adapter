{
  "name": "@aptos-labs/wallet-adapter",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "lint": "biome lint .",
    "test": "turbo run test",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset version && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.29.7",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.5",
  "pnpm": {
    "overrides": {
      "@aptos-labs/aptos-client": "^3.0.0",
      "@aptos-labs/ts-sdk": "^6.1.0",
      "@aptos-labs/wallet-standard": "^1.0.0",
      "glob@^10": "^10.5.0",
      "valibot@<1.2.0": "^1.2.0",
      "react-router@^7": "^7.12.0",
      "axios@^1": "^1.13.5",
      "minimatch@^3": "^3.1.4",
      "minimatch@^9": "^9.0.7",
      "rollup@^4": "^4.59.0",
      "vite@^6": "^6.4.1",
      "js-yaml@^3": "^3.14.2",
      "bn.js@^4": "^4.12.3",
      "bn.js@^5": "^5.2.3",
      "ajv@^6": "^6.14.0",
      "brace-expansion@^2": "^2.0.2"
    }
  }
}
