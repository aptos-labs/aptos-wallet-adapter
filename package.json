{
  "name": "@aptos-labs/wallet-adapter",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "lint": "biome lint .",
    "test": "turbo run test",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset version && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@changesets/cli": "^2.29.7",
    "turbo": "latest",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-3gc7-fjrx-p6mg",
        "GHSA-848j-6mx2-7j84"
      ]
    },
    "overrides": {
      "typescript": "6.0.2",
      "pbkdf2": "^3.1.3",
      "form-data": "^4.0.4",
      "sha.js": "^2.4.12",
      "axios": "1.15.0",
      "devalue": "^5.3.2",
      "esbuild": ">=0.25.0",
      "koa": "^2.16.1",
      "vite": "^6.4.2",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "valibot@>=0.31.0 <1.2.0": ">=1.2.0",
      "react-router@>=7.0.0 <7.12.0": ">=7.12.0",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "js-yaml@<3.14.2": ">=3.14.2",
      "bn.js@>=5.0.0 <5.2.3": ">=5.2.3",
      "bn.js@<4.12.3": ">=4.12.3",
      "bn.js@5.2.1": "5.2.3",
      "ethereumjs-abi>bn.js": "5.2.3",
      "ethereumjs-util>bn.js": "5.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "picomatch@4.0.2": "4.0.4",
      "micromatch>picomatch": "4.0.4",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "yaml@2.8.1": "2.8.3",
      "cosmiconfig>yaml": "2.8.3",
      "happy-dom@<20.8.9": ">=20.8.9",
      "protobufjs@<7.5.5": ">=7.5.5"
    }
  }
}
